<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Main app theme ──────────────────────────────────────────────── -->
    <style name="Theme.FrankyIndustrial" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/acc</item>
        <item name="colorPrimaryVariant">@color/acc2</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/acc2</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg2</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColorPrimary">@color/txt</item>
        <item name="android:textColorSecondary">@color/txt2</item>
        <!-- Consistent Roboto Medium across the app -->
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ── Button base ─────────────────────────────────────────────────── -->
    <!-- All FrankyBtn variants use ripple via MaterialButton's built-in ripple -->
    <style name="FrankyBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/ripple_light</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="FrankyBtn.Orange">
        <item name="backgroundTint">@color/acc</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="FrankyBtn.Red">
        <item name="backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="FrankyBtn.Green">
        <item name="backgroundTint">@color/ok</item>
        <item name="android:textColor">@color/black</item>
        <item name="rippleColor">@color/ripple_dark</item>
    </style>

    <style name="FrankyBtn.Blue">
        <item name="backgroundTint">@color/info</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="FrankyBtn.Dark" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/bg3</item>
        <item name="android:textColor">@color/txt</item>
        <item name="strokeColor">@color/brd</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="rippleColor">@color/ripple_mid</item>
    </style>

    <!-- ── D-PAD button — large touch target with ripple ───────────────── -->
    <style name="FrankyBtn.Dpad" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/bg3</item>
        <item name="android:textColor">@color/txt</item>
        <item name="strokeColor">@color/brd</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/acc</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="FrankyBtn.Dpad.Stop">
        <item name="backgroundTint">@color/danger_dim</item>
        <item name="android:textColor">@color/danger</item>
        <item name="strokeColor">@color/danger</item>
        <item name="rippleColor">@color/danger</item>
    </style>

</resources>
