<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A1218" />
            <stroke android:width="1dp" android:color="@color/info" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp" android:left="0dp" android:width="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/info" />
            <corners android:topLeftRadius="6dp" android:bottomLeftRadius="6dp" />
        </shape>
    </item>
</layer-list>
