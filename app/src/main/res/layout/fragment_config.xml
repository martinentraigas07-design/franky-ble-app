<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <include layout="@layout/view_toolbar"
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="14dp"   android:paddingBottom="24dp">

            <!-- ADC availability banner -->
            <TextView
                android:id="@+id/tvAdcBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_banner"
                android:padding="12dp"
                android:text="ADC disponibles: 2 (GPIO0 + GPIO1)"
                android:textColor="@color/warn"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <!-- Line sensor warning (hidden unless SPI active) -->
            <TextView
                android:id="@+id/tvLineWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_banner"
                android:padding="12dp"
                android:text="⚠ Con SPI activo: máximo 1 sensor de línea (1 ADC disponible)"
                android:textColor="@color/danger"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <!-- BUSES card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BUSES DE COMUNICACIÓN"
                    android:textColor="@color/acc2" android:textSize="12sp"
                    android:textStyle="bold" android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- I2C -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingTop="8dp" android:paddingBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bus I2C" android:textColor="@color/txt"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GPIO6 (SDA) / GPIO7 (SCL)"
                            android:textColor="@color/txt2" android:textSize="11sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchI2c"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:thumbTint="@color/acc" app:trackTint="@color/bg3" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/brd" />

                <!-- SPI -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingTop="8dp" android:paddingBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bus SPI" android:textColor="@color/txt"
                            android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GPIO20/21 (CLK/MOSI) · GPIO1 (MISO) · GPIO10 (CS)"
                            android:textColor="@color/txt2" android:textSize="11sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSpi"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:thumbTint="@color/acc" app:trackTint="@color/bg3" />
                </LinearLayout>
            </LinearLayout>

            <!-- DISTANCE SENSOR card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SENSOR DE DISTANCIA"
                    android:textColor="@color/acc2" android:textSize="12sp"
                    android:textStyle="bold" android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <!-- RadioGroup for sensor type -->
                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbDistNone"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Ninguno"
                        android:textColor="@color/txt" android:textSize="13sp"
                        android:paddingTop="6dp" android:paddingBottom="6dp"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbDistSonar"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="HC-SR04 (Ultrasónico)"
                        android:textColor="@color/txt" android:textSize="13sp"
                        android:paddingTop="6dp" android:paddingBottom="6dp" />

                    <RadioButton
                        android:id="@+id/rbDistSharp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Sharp GP2Y (Infrarrojo)"
                        android:textColor="@color/txt" android:textSize="13sp"
                        android:paddingTop="6dp" android:paddingBottom="6dp" />

                    <RadioButton
                        android:id="@+id/rbDistTof"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="ToF I²C (requiere I2C activo)"
                        android:textColor="@color/txt" android:textSize="13sp"
                        android:paddingTop="6dp" android:paddingBottom="6dp" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/brd" android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cantidad de sensores (1–3):"
                    android:textColor="@color/txt2" android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerDistCount"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card" />
            </LinearLayout>

            <!-- LINE SENSORS card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SENSORES DE LÍNEA (ADC)"
                    android:textColor="@color/acc2" android:textSize="12sp"
                    android:textStyle="bold" android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Usan GPIO0 (ADC0) y GPIO1 (ADC1). ADC1 no disponible con SPI activo."
                    android:textColor="@color/txt2" android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerLineCount"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card" />
            </LinearLayout>

            <!-- Status label -->
            <TextView
                android:id="@+id/tvConfigStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/txt2"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Apply button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyConfig"
                style="@style/FrankyBtn.Orange"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✓  APLICAR CONFIGURACIÓN"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- Back button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfigBack"
                style="@style/FrankyBtn.Dark"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⌂  Volver"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
