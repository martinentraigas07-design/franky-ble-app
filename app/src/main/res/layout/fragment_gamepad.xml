<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Toolbar -->
    <include
        layout="@layout/view_toolbar"
        android:id="@+id/toolbar" />

    <!-- Mode tabs — D-PAD / JOYSTICK -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg2"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeDpad"
            style="@style/FrankyBtn.Orange"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="D-PAD"
            android:textSize="12sp"
            android:layout_marginEnd="5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeJoy"
            style="@style/FrankyBtn.Dark"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="JOYSTICK"
            android:textSize="12sp"
            android:layout_marginStart="5dp" />
    </LinearLayout>

    <!-- Control area — fills available height -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── D-PAD panel ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/frameDpad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="280dp"
                android:layout_height="280dp">

                <!-- UP -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnU"
                    style="@style/FrankyBtn.Dpad"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="▲"
                    android:textSize="30sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- DOWN -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnD"
                    style="@style/FrankyBtn.Dpad"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="▼"
                    android:textSize="30sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- LEFT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnL"
                    style="@style/FrankyBtn.Dpad"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="◀"
                    android:textSize="30sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- CENTER STOP -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDpadStop"
                    style="@style/FrankyBtn.Dpad.Stop"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="■"
                    android:textSize="28sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- RIGHT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnR"
                    style="@style/FrankyBtn.Dpad"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="▶"
                    android:textSize="30sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <!-- ── JOYSTICK panel ────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/frameJoy"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <com.franky.robot.ui.components.JoystickView
                android:id="@+id/joystick"
                android:layout_width="290dp"
                android:layout_height="290dp"
                android:layout_gravity="center" />

        </FrameLayout>

    </FrameLayout>

    <!-- ── Speed + action buttons ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Speed row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PWM"
                android:textColor="@color/txt2"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium" />

            <SeekBar
                android:id="@+id/seekSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progress="200"
                android:progressTint="@color/acc"
                android:thumbTint="@color/acc2" />

            <TextView
                android:id="@+id/tvSpeedPct"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="78%"
                android:textColor="@color/txt"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:gravity="end" />
        </LinearLayout>

        <!-- Turbo + Stop buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTurbo"
                style="@style/FrankyBtn.Green"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="⚡ TURBO"
                android:textSize="14sp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/FrankyBtn.Red"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="■ STOP"
                android:textSize="14sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Back -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/FrankyBtn.Dark"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="⌂  Volver"
        android:textSize="13sp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
