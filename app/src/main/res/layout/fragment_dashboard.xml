<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <include layout="@layout/view_toolbar"
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Quick status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="8dp" android:paddingBottom="8dp">

        <TextView android:id="@+id/tvConnChip"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CONECTADO" android:textColor="@color/ok"
            android:textSize="11sp" android:textStyle="bold"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp"
            android:background="@drawable/bg_badge"
            android:layout_marginEnd="8dp" />

        <TextView android:id="@+id/tvModeChip"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="IDLE" android:textColor="@color/txt2"
            android:textSize="11sp" android:textStyle="bold" />

        <android.widget.Space android:layout_width="0dp"
            android:layout_height="1dp" android:layout_weight="1" />

        <TextView android:id="@+id/tvAdc"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ADC: --" android:textColor="@color/txt2" android:textSize="11sp"
            android:fontFamily="monospace" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/tvTemp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="-- °C" android:textColor="@color/txt"
            android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/tvHum"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="-- %" android:textColor="@color/txt"
            android:textSize="12sp" android:fontFamily="monospace"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="16dp" android:paddingBottom="24dp">

            <!-- Module grid — 2 columns -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoGamepad"
                    style="@style/FrankyBtn.Orange"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="🎮\nGamepad"
                    android:textSize="13sp"
                    android:layout_marginEnd="5dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoPanel"
                    style="@style/FrankyBtn.Blue"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="📊\nPanel"
                    android:textSize="13sp"
                    android:layout_marginStart="5dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoSumo"
                    style="@style/FrankyBtn.Green"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="🥊\nSumo"
                    android:textSize="13sp"
                    android:layout_marginEnd="5dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoConfig"
                    style="@style/FrankyBtn.Dark"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="⚙️\nConfiguración"
                    android:textSize="12sp"
                    android:layout_marginStart="5dp" />
            </LinearLayout>

            <!-- Emergency stop -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEStop"
                style="@style/FrankyBtn.Red"
                android:layout_width="match_parent" android:layout_height="60dp"
                android:text="■■  PARAR TODO"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                style="@style/FrankyBtn.Dark"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="⏻  Desconectar"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
