<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar"
        android:orientation="horizontal"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FRANKY 4.0" android:textColor="@color/txt"
                android:textSize="17sp" android:textStyle="bold" android:letterSpacing="0.05" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Programación con Bloques" android:textColor="@color/txt2" android:textSize="11sp" />
        </LinearLayout>
        <TextView android:id="@+id/tvBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_badge" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp" android:text="EDITOR"
            android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Status bar — mirrors .prog-bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg3"
        android:orientation="horizontal"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#333333" />

        <TextView
            android:id="@+id/tvStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cargando editor..."
            android:textColor="@color/txt"
            android:textSize="13sp"
            android:layout_marginStart="10dp" />

        <ProgressBar
            android:id="@+id/pbXml"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="@color/acc"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvBlockCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 bloques"
            android:textColor="@color/txt2"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Tabs — mirrors .tabs from bloques.html -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        android:orientation="horizontal"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="10dp">

        <TextView
            android:id="@+id/tabEditor"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:text="Editor"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tabInstructions"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:text="Instrucciones"
            android:textColor="@color/txt2"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Tab content -->
    <FrameLayout
        android:id="@+id/tabContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp">

        <!-- Editor WebView panel -->
        <LinearLayout
            android:id="@+id/panelEditor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Send button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendBlockly"
                style="@style/FrankyBtn.Orange"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="▶  CARGAR A FRANKY"
                android:textSize="15sp"
                android:layout_margin="14dp" />
        </LinearLayout>

        <!-- Instructions panel -->
        <ScrollView
            android:id="@+id/panelInstructions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginTop="0dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="INSTRUCCIONES ENVIADAS AL ROBOT"
                        android:textColor="@color/acc2" android:textSize="12sp"
                        android:textStyle="bold" android:letterSpacing="0.08"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="// Sin instrucciones enviadas"
                        android:textColor="#79C0FF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:background="#0D1117"
                        android:padding="12dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackFromBlockly"
                    style="@style/FrankyBtn.Dark"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="⌂  Volver"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
